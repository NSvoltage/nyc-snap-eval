# Copy this file to .env and fill in real values. .env is gitignored.

# --- Anthropic API ---
# Used for: system under test (Sonnet 4.5), judge model (Opus 4.5)
ANTHROPIC_API_KEY=sk-ant-...

# --- OpenAI API (for comparison runs) ---
# Used for: GPT-4o comparison runs, GPT-4o as cross-judge when Opus is under test
OPENAI_API_KEY=sk-...

# --- Google Generative AI (for comparison runs) ---
# Used for: Gemini 2.5 Pro comparison runs
GOOGLE_API_KEY=...

# --- Voyage embeddings ---
# Used for: corpus chunking and retrieval in the reference implementation
VOYAGE_API_KEY=pa-...

# --- Supabase (pgvector for RAG) ---
# Used for: storing chunked policy corpus with embeddings
SUPABASE_URL=https://....supabase.co
SUPABASE_ANON_KEY=...
SUPABASE_SERVICE_ROLE_KEY=...

# --- NYC Benefits Screening API ---
# Used for: deterministic eligibility computation in the reference implementation
# Note: per ADR-005, this API is open without auth for basic use. If rate limiting requires
# a key in production, document it here.
NYC_SCREENING_API_BASE_URL=https://screeningapidocs.cityofnewyork.us

# --- Promptfoo ---
# Used for: the eval harness. Most config lives in promptfooconfig.yaml.
PROMPTFOO_LOG_LEVEL=info

# --- Demo deployment ---
# Used for: Vercel deployment of the reference implementation
VERCEL_URL=
